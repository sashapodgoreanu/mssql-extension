{
    "version": "0.2.0",
    "configurations": [
    {
      "name": "Attach native to running C# process",
      "type": "cppvsdbg",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": false,
      "symbolSearchPath": "${workspaceFolder}/build/debug/extension/mssql;${workspaceFolder}/build/debug/src"
    },
        {
            "name": "Debug DuckDB (Windows MSVC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/duckdb.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "DUCKDB_ALLOW_UNSIGNED_EXTENSIONS",
                    "value": "1"
                },
                {
                    "name": "MSSQL_DEBUG",
                    "value": "3"
                }
            ],
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Debug Tests (Windows MSVC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/test/unittest.exe",
            "args": ["*mssql*", "--force-reload"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Debug (Windows MSVC)",
            "environment": [
                {
                    "name": "DUCKDB_ALLOW_UNSIGNED_EXTENSIONS",
                    "value": "1"
                },
                {
                    "name": "MSSQL_DEBUG",
                    "value": "3"
                }
            ],
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Debug",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/duckdb",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Debug",
            "env": {
                "DUCKDB_ALLOW_UNSIGNED_EXTENSIONS": "1",
                "MSSQL_DEBUG": "3"
            },
            "stopOnEntry": false,
            "sourceMap": {
                "/Users/vgribanov/projects/hugr-lab/mssql-extension": "${workspaceFolder}"
            }
        },
        {
            "name": "Release",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/release/duckdb",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Release",
            "env": {
                "DUCKDB_ALLOW_UNSIGNED_EXTENSIONS": "1",
                "MSSQL_DEBUG": "0"
            },
            "stopOnEntry": false,
            "sourceMap": {
                "/Users/vgribanov/projects/hugr-lab/mssql-extension": "${workspaceFolder}"
            }
        },
        {
            "name": "Debug Tests",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/test/unittest",
            "args": ["--test-dir", "${workspaceFolder}/test/sql", "*mssql*"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Debug",
            "stopOnEntry": false,
            "sourceMap": {
                "/Users/vgribanov/projects/hugr-lab/mssql-extension": "${workspaceFolder}"
            }
        }
    ]
}
